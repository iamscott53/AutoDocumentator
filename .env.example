# ──────────────────────────────────────────────────────────────
# AutoDocumentator – Segra M365 Copilot Configuration
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to source control.
# ──────────────────────────────────────────────────────────────

# Feature flag — which AI provider to use
AI_PROVIDER=segra_copilot

# ── Entra ID (Azure AD) ──────────────────────────────────────
# From your Entra ID app registration
AZURE_TENANT_ID=
AZURE_CLIENT_ID=

# Only needed for daemon / app-only flow (not recommended for desktop)
# AZURE_CLIENT_SECRET=

# ── Azure OpenAI ─────────────────────────────────────────────
# Your enterprise Azure OpenAI resource
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Auth method for Azure OpenAI: "key" or "entra" (Azure AD token)
AZURE_OPENAI_AUTH=key
# Only needed if AZURE_OPENAI_AUTH=key
AZURE_OPENAI_API_KEY=

# ── Microsoft Graph (optional – for tenant document grounding) ─
# Set to "true" to search tenant docs for SOP templates/policies
GRAPH_GROUNDING_ENABLED=false
# Search query to find relevant grounding docs in tenant
GRAPH_GROUNDING_QUERY=SOP template standard operating procedure
